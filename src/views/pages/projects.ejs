<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
    <%- include('../partials/navbar') %>

    <%
        const technologies = Array.from(
            new Set(
                (projects || []).flatMap((project) => {
                    if (Array.isArray(project.technologies)) {
                        return project.technologies
                            .map((technology) => String(technology || "").trim())
                            .filter(Boolean);
                    }

                    if (typeof project.technologies === "string") {
                        return project.technologies
                            .split(",")
                            .map((technology) => technology.trim())
                            .filter(Boolean);
                    }

                    return [];
                })
            )
        ).sort((a, b) => a.localeCompare(b));
    %>

    <main class="container page page-projects">
        <section class="page-header reveal-on-scroll">
            <span class="eyebrow">Projects</span>
            <h1>Games, Apps, and Technical Builds</h1>
            <p>Browse development work across software, tools, game systems, and creative projects.</p>
        </section>

        <section class="filter-bar reveal-on-scroll">
            <div class="filter-search-wrap">
                <input type="search" id="project-search" class="filter-search" placeholder="Search projects by title, category, or technology">
            </div>

            <div class="filter-controls">
                <div class="custom-select" id="project-technology-select" data-selected="all">
                    <button
                        type="button"
                        class="custom-select-trigger"
                        id="project-technology-trigger"
                        aria-haspopup="listbox"
                        aria-expanded="false"
                    >
                        <span class="custom-select-label">All Technologies</span>
                        <span class="custom-select-chevron" aria-hidden="true">&#9662;</span>
                    </button>

                    <div class="custom-select-menu hidden" id="project-technology-menu" role="listbox" aria-label="Filter by technology">
                        <button
                            type="button"
                            class="custom-select-option is-selected"
                            data-value="all"
                            role="option"
                            aria-selected="true"
                        >
                            All Technologies
                        </button>

                        <% technologies.forEach((technology) => { %>
                            <button
                                type="button"
                                class="custom-select-option"
                                data-value="<%= technology.toLowerCase() %>"
                                role="option"
                                aria-selected="false"
                            >
                                <%= technology %>
                            </button>
                        <% }) %>
                    </div>
                </div>

                <div class="filter-buttons">
                    <button class="filter-btn is-active" type="button" data-filter="all">All</button>
                    <button class="filter-btn" type="button" data-filter="game">Games</button>
                    <button class="filter-btn" type="button" data-filter="app">Apps</button>
                </div>
            </div>
        </section>

        <section class="project-grid" id="project-grid">
            <% if (projects && projects.length) { %>
                <% projects.forEach(project => { %>
                    <%- include('../partials/project-card', { project: project }) %>
                <% }) %>
            <% } else { %>
                <p class="empty-state">No projects available.</p>
            <% } %>
        </section>

        <p id="project-empty-message" class="empty-state hidden">No projects match your current filter.</p>
    </main>

    <%- include('../partials/footer') %>

    <script src="/js/main.js"></script>
    <script src="/js/nav.js"></script>
    <script src="/js/project-filters.js"></script>
</body>
</html>