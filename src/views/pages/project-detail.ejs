<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
    <%- include('../partials/navbar') %>

    <main class="container page page-project-detail">
        <section class="project-hero reveal-on-scroll">
            <div>
                <span class="eyebrow">Project Details</span>
                <h1><%= project.title %></h1>
                <p class="project-summary"><%= project.description %></p>
            </div>

            <% if (project.image) { %>
                <img src="/images/projects/<%= project.image %>" alt="<%= project.title %>" class="project-image">
            <% } %>
        </section>

        <section class="project-info reveal-on-scroll">
            <div class="project-meta detail-card">
                <p><strong>Category:</strong> <%= project.category || 'Project' %></p>

                <% if (project.role) { %>
                    <p><strong>Role:</strong> <%= project.role %></p>
                <% } %>
            </div>

            <div class="project-links">
                <% if (project.github) { %>
                    <a href="<%= project.github %>" target="_blank" rel="noreferrer" class="btn btn-secondary">
                        GitHub Repository
                    </a>
                <% } %>

                <% if (project.demo) { %>
                    <a href="<%= project.demo %>" target="_blank" rel="noreferrer" class="btn btn-primary">
                        View Release
                    </a>
                <% } %>

                <% if (project.website) { %>
                    <a href="<%= project.website %>" target="_blank" rel="noreferrer" class="btn btn-primary">
                        Visit Website
                    </a>
                <% } %>
            </div>
        </section>
    </main>

    <%- include('../partials/footer') %>

    <script src="/js/main.js"></script>
    <script src="/js/nav.js"></script>
</body>
</html>
