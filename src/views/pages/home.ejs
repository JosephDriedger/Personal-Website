<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head') %>
<body>
    <%- include('../partials/navbar') %>

    <main class="container page page-home">
        <section class="hero reveal-on-scroll">
            <div class="hero-copy">
                <span class="eyebrow">Portfolio</span>
                <h1>Game developer, software engineer, and creative builder.</h1>
                <p>
                    I build games, apps, tools, and media projects with a focus on polished user experiences,
                    strong technical foundations, and creative problem solving.
                </p>

                <div class="hero-actions">
                    <a href="/projects" class="btn btn-primary">View Projects</a>
                    <a href="/music-videos" class="btn btn-secondary">Watch Music Videos</a>
                </div>
            </div>

            <div class="hero-panel">
                <div class="stat-card">
                    <strong>Focus Areas</strong>
                    <ul>
                        <li>Games & engines</li>
                        <li>Web apps & tools</li>
                        <li>Creative video content</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="featured-projects reveal-on-scroll">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">Featured Work</span>
                    <h2>Highlighted projects</h2>
                </div>
                <a href="/projects" class="text-link">See all projects</a>
            </div>

            <div class="project-grid">
                <% if (projects && projects.length) { %>
                    <% projects.forEach(project => { %>
                        <%- include('../partials/project-card', { project: project }) %>
                    <% }) %>
                <% } else { %>
                    <p class="empty-state">No projects available right now.</p>
                <% } %>
            </div>
        </section>
    </main>

    <%- include('../partials/footer') %>

    <script src="/js/main.js"></script>
    <script src="/js/nav.js"></script>
</body>
</html>
